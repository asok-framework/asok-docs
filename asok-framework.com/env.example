# ------------------------------------------------------------------------------
# Asok Documentation Site - Production Configuration
# ------------------------------------------------------------------------------

# Core
DEBUG=false
SECRET_KEY=generate-a-strong-key-with-asok-shell
PROJECT_NAME="Asok Framework"
VERSION=0.1.1
LOCALE=en

# Server
APP_URL=https://asok-framework.com
ASOK_PORT=8000
# WebSocket port (if using reactive search or components)
WS_PORT=8001
ASOK_WRITE_BYTECODE=false

# Security
CORS_ORIGINS=https://asok-framework.com
STRICT_ORIGIN_CHECK=true

# Documentation Content
# Path to the .md files relative to app root
DOCS_SOURCE_PATH=../docs/

# Disable API Auto-Docs (not needed on the marketing site)
ASOK_DOCS=false
DOCS=false

# Caching (Critical for documentation speed)
SESSION_BACKEND=cookie
CACHE_BACKEND=file
CACHE_PATH=.cache
# Cache TTL for rendered markdown (in seconds)
DOCS_CACHE_TTL=3600

# Performance & Optimization (Extreme)
GZIP=true
GZIP_MIN_SIZE=256
HTML_MINIFY=true
IMAGE_OPTIMIZATION=true
IMAGE_KEEP_ORIGINAL=false

# Logging
LOG_LEVEL=ERROR
LOG_FILE=logs/docs_site.log
